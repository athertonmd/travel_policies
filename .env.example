# TPIP Configuration

# API Server
PORT=3001
NODE_ENV=development

# Database (Aurora PostgreSQL in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tpip

# AWS
AWS_REGION=eu-west-1
S3_BUCKET=tpip-policy-documents

# Optional: AWS credentials (use IAM roles in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
