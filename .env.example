# TPIP Configuration

# Storage Mode: 'local' (no Docker/PostgreSQL) or 'aws' (S3 + PostgreSQL)
TPIP_STORAGE_MODE=local

# Local data directory (used when TPIP_STORAGE_MODE=local)
TPIP_LOCAL_DATA_DIR=./.tpip-data

# API Server
PORT=3001
NODE_ENV=development

# Database (Aurora PostgreSQL in production, only needed when TPIP_STORAGE_MODE=aws)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tpip

# AWS (only needed when TPIP_STORAGE_MODE=aws)
AWS_REGION=eu-west-1
S3_BUCKET=tpip-policy-documents

# Optional: AWS credentials (use IAM roles in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
